---
import Head from "@components/Head.astro";
import "@assets/intro/base.css";
import Nav from "@components/Nav.astro";

const certificates = [
	{
		title: "AI for Content Creation",
		issuer: "Google · Coursera",
		date: "Mar 22, 2026",
		link: "https://www.coursera.org/account/accomplishments/verify/WP43JMYQLO5J",
		icon: "fa-solid fa-pen-nib"
	},
	{
		title: "AI for Writing and Communicating",
		issuer: "Google · Coursera",
		date: "Mar 22, 2026",
		link: "https://www.coursera.org/account/accomplishments/verify/Q8T5QUEU52XY",
		icon: "fa-solid fa-message"
	},
	{
		title: "AI for Brainstorming and Planning",
		issuer: "Google · Coursera",
		date: "Mar 22, 2026",
		link: "https://www.coursera.org/account/accomplishments/verify/N4PZ4P849321",
		icon: "fa-solid fa-lightbulb"
	},
	{
		title: "AI Fundamentals",
		issuer: "Google · Coursera",
		date: "Mar 22, 2026",
		link: "https://www.coursera.org/account/accomplishments/verify/FG1P8VPC12XB",
		icon: "fa-solid fa-microchip"
	},
	{
		title: "Use AI Responsibly",
		issuer: "Google · Coursera",
		date: "Mar 2, 2026",
		link: "https://www.coursera.org/account/accomplishments/verify/CP8UQCFNSE6K",
		icon: "fa-solid fa-shield-halved"
	},
	{
		title: "Discover the Art of Prompting",
		issuer: "Google · Coursera",
		date: "Mar 2, 2026",
		link: "https://www.coursera.org/account/accomplishments/verify/S3HC4U0KYBQD",
		icon: "fa-solid fa-wand-magic-sparkles"
	},
	{
		title: "Maximize Productivity With AI Tools",
		issuer: "Google · Coursera",
		date: "Feb 27, 2026",
		link: "https://www.coursera.org/account/accomplishments/verify/WDZA4OS1PCTJ",
		icon: "fa-solid fa-bolt"
	},
	{
		title: "Introduction to AI",
		issuer: "Google · Coursera",
		date: "Feb 27, 2026",
		link: "https://www.coursera.org/account/accomplishments/verify/SL6Z4JXQI4T0",
		icon: "fa-solid fa-robot"
	}
];
---

<html lang="en" data-default-color-scheme="auto">
	<head>
		<Head path="code" title="Google Certificates - Gaurav Patel" description="Verified Google Certificates through Coursera" theme="#333" />
		<style is:global>
			body {
				background-color: rgb(20, 20, 20);
				overflow-x: hidden;
				color: rgb(240, 240, 240);
			}

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			header {
				min-height: 100vh;
				width: 100%;
				height: 100vh;
				position: relative;
				z-index: 3;
			}

			footer {
				text-align: center;
				padding: 2rem;
				background-color: #000000a7;
				position: relative;
				z-index: 3;
			}

			@keyframes rotate {
				from {
					rotate: 0deg;
				}

				50% {
					scale: 1 1.5;
				}

				to {
					rotate: 360deg;
				}
			}

			#blob {
				background-color: white;
				height: 34vmax;
				aspect-ratio: 1;
				position: absolute;
				left: 50%;
				top: 50%;
				translate: -50% -50%;
				border-radius: 50%;
				background: linear-gradient(to right, aquamarine, mediumpurple);
				animation: rotate 20s infinite;
				opacity: 0.8;
				z-index: 1;
			}

			#blur {
				height: 100%;
				width: 100%;
				position: fixed;
				z-index: 2;
				filter: blur(12vmax);
			}

			h1 {
				font-size: clamp(3rem, 10vw, 10rem);
				color: white;
				white-space: nowrap;
				padding: 0rem clamp(1rem, 2vw, 3rem);
				border-radius: clamp(0.4rem, 0.75vw, 1rem);
			}

			.text {
				width: 100%;
				height: 100vh;
				display: flex;
				justify-content: center;
				align-items: center;
				flex-direction: column;
				position: absolute;
				left: 0;
				top: 0;
				z-index: 3;
			}

			main {
				align-items: center;
				background: linear-gradient(#00000000, #000000a7 10rem, #000000a7);
				display: flex;
				justify-content: center;
				margin: 0px;
				overflow: hidden;
				padding: 0px;
				position: relative;
				z-index: 3;
			}

			#cards {
				display: flex;
				flex-direction: column;
				gap: 16px;
				max-width: 800px;
				width: calc(100% - 40px);
				padding-bottom: 5rem;
			}

			#cards:hover > .card::after {
				opacity: 1;
			}

			.card {
				background-color: rgba(255, 255, 255, 0.1);
				border-radius: 10px;
				cursor: pointer;
				display: flex;
				height: 120px;
				flex-direction: row;
				position: relative;
				width: 100%;
			}

			.card:hover::before {
				opacity: 1;
			}

			.card::before,
			.card::after {
				border-radius: inherit;
				content: "";
				height: 100%;
				left: 0px;
				opacity: 0;
				position: absolute;
				top: 0px;
				transition: opacity 500ms;
				width: 100%;
			}

			.card::before {
				background: radial-gradient(800px circle at var(--mouse-x) var(--mouse-y), rgba(255, 255, 255, 0.06), transparent 40%);
				z-index: 3;
			}

			.card::after {
				background: radial-gradient(600px circle at var(--mouse-x) var(--mouse-y), rgba(255, 255, 255, 0.4), transparent 40%);
				z-index: 1;
			}

			.card > .card-content {
				background-color: rgb(23, 23, 23);
				border-radius: inherit;
				display: flex;
				flex-direction: row;
				align-items: center;
				flex-grow: 1;
				inset: 1px;
				padding: 20px;
				position: absolute;
				z-index: 2;
			}

			h1,
			h2,
			h3,
			h4,
			span {
				font-weight: 400;
			}

			.card-image {
				align-items: center;
				display: flex;
				height: 80px;
				width: 80px;
				justify-content: center;
				overflow: hidden;
				flex-shrink: 0;
			}

			.card-image > i {
				font-size: 3em;
				opacity: 0.25;
			}

			.card-info-wrapper {
				align-items: center;
				display: flex;
				flex-grow: 1;
				justify-content: flex-start;
				padding: 0px 20px;
			}

			.card-info {
				align-items: flex-start;
				display: flex;
				gap: 10px;
			}

			.card-info > i {
				font-size: 1em;
				height: 20px;
				line-height: 20px;
			}

			.card-info-title > h3 {
				font-size: 1.1em;
				line-height: 20px;
			}

			.card-info-title > h4 {
				color: rgba(255, 255, 255, 0.5);
				font-size: 0.85em;
				margin-top: 8px;
			}

			@media (max-width: 600px) {
				.card {
					height: auto;
					min-height: 100px;
					padding: 10px;
				}
				.card > .card-content {
					padding: 10px;
				}
				.card-image {
					width: 50px;
					height: 50px;
				}
				.card-image > i {
					font-size: 2em;
				}
				.card-info-title > h3 {
					font-size: 1em;
				}
			}

			@media (max-width: 320px) {
				.card {
					width: 100%;
				}
			}
		</style>
		<script src="https://kit.fontawesome.com/5b12cc2fae.js" crossorigin="anonymous"></script>
	</head>
	<body>
		<div id="blur"><div id="blob"></div></div>
		<Nav blur="true" />
		<header>
			<div class="text">
				<h1 data-value="CERTIFICATES">CERTIFICATES</h1>
				<h2>Verified Google Certificates</h2>
			</div>
		</header>
		<main>
			<div id="cards">
				{
					certificates.map(cert => (
						<div class="card" data-link={cert.link}>
							<div class="card-content">
								<div class="card-image">
									<i class={cert.icon} />
								</div>
								<div class="card-info-wrapper">
									<div class="card-info">
										<div class="card-info-title">
											<h3>{cert.title}</h3>
											<h4>
												{cert.issuer} · {cert.date}
											</h4>
										</div>
									</div>
								</div>
							</div>
						</div>
					))
				}
			</div>
		</main>
		<script src="@assets/intro/style.js"></script>
		<footer>
			<p>© 2026 by Gaurav Patel</p>
		</footer>
		<script is:inline>
			/* -- Glow effect -- */
			const blob = document.getElementById("blob");
			window.onpointermove = event => {
				const { clientX, clientY } = event;
				blob.animate(
					{
						left: `${clientX}px`,
						top: `${clientY}px`
					},
					{ duration: 3000, fill: "forwards" }
				);
			};

			/* -- Text effect -- */
			const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
			let interval = null;
			document.querySelector("h1").onmouseover = event => {
				let iteration = 0;
				clearInterval(interval);
				interval = setInterval(() => {
					event.target.innerText = event.target.innerText
						.split("")
						.map((letter, index) => {
							if (letter === " ") return " ";
							if (index < iteration) return event.target.dataset.value[index];
							return letters[Math.floor(Math.random() * 26)];
						})
						.join("");
					if (iteration >= event.target.dataset.value.length) {
						clearInterval(interval);
					}
					iteration += 1 / 3;
				}, 30);
			};

			/* -- Card effect -- */
			document.getElementById("cards").onmousemove = e => {
				for (const card of document.getElementsByClassName("card")) {
					const rect = card.getBoundingClientRect(),
						x = e.clientX - rect.left,
						y = e.clientY - rect.top;

					card.style.setProperty("--mouse-x", `${x}px`);
					card.style.setProperty("--mouse-y", `${y}px`);
				}
			};

			const myDivs = document.querySelectorAll(".card");
			myDivs.forEach(function (div) {
				div.addEventListener("click", function () {
					window.open(div.getAttribute("data-link"), "_blank");
				});
			});
		</script>
		<script>
			(() => {
				const nav = document.querySelector("nav.filter");
				if (!nav) return;
				window.onscroll = () => {
					nav.classList.toggle("filter", window.scrollY > window.innerHeight);
				};
			})();
		</script>
	</body>
</html>
