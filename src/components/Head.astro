---
const { i18n = [], path = "", favicon = true, ga = false, title, description, image, theme = "#000" } = Astro.props;
const links = i18n
	.map(lang => {
		const url = lang === "en" ? "" : "/" + lang;
		return `<link rel="alternate" hreflang="${lang}" href="https://iamgs05.github.io${url}/${path}" />`;
	})
	.join("\n");

const xDefault = `<link rel="alternate" hreflang="x-default" href="https://iamgs05.github.io/${path}" />`;
const canonical = `https://iamgs05.github.io/${path}`;
const fullImage = `https://iamgs05.github.io${image}`;
---

<!-- Meta tags -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

{title && <title>{title}</title>}
{description && <meta name="description" content={description} />}
{title && <meta property="og:title" content={title} />}
{canonical && <meta property="og:url" content={canonical} />}
{fullImage && image && <meta property="og:image" content={fullImage} />}
{description && <meta property="og:description" content={description} />}
{theme && <meta name="theme-color" content={theme} />}

<!-- i18n alternate links -->
<Fragment set:html={`${links}\n${xDefault}`} />

<!-- Favicon -->
{
	favicon && (
		<>
			<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		</>
	)
}

<!-- Google Analytics -->
{
	ga && (
		<>
			<script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" />
			<script is:inline>
				{`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-XXXXXXXXXX');`}
			</script>
		</>
	)
}
